---
export interface Props {
  width?: number;
  height?: number;
  class?: string;
}

const { width = 28, height = 28, class: className } = Astro.props;
---

<svg class={className} width={width} height={height} viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="go-workflow-auditlog logo">
  <rect width="28" height="28" rx="6" class="fill-[var(--color-accent)]" />
  <circle cx="14" cy="6" r="2.2" class="fill-[var(--color-bg-primary)]" />
  <circle cx="7" cy="14" r="2.2" class="fill-[var(--color-bg-primary)]" />
  <circle cx="21" cy="14" r="2.2" class="fill-[var(--color-bg-primary)]" />
  <circle cx="14" cy="22" r="2.2" class="fill-[var(--color-bg-primary)]" />
  <path d="M12.5 7.5L8.5 12.5" stroke="var(--color-bg-primary)" stroke-width="1.5" stroke-linecap="round" />
  <path d="M15.5 7.5L19.5 12.5" stroke="var(--color-bg-primary)" stroke-width="1.5" stroke-linecap="round" />
  <path d="M8.5 15.5L12.5 20.5" stroke="var(--color-bg-primary)" stroke-width="1.5" stroke-linecap="round" />
  <path d="M19.5 15.5L15.5 20.5" stroke="var(--color-bg-primary)" stroke-width="1.5" stroke-linecap="round" />
</svg>

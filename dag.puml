@startuml
skinparam componentStyle uml2
skinparam defaultFontSize 12

[fetch [Succeeded\]] as fetch #2d5a2d;text:#fff
[flaky-api-call [Succeeded\] (×3)] as flaky_api_call #2d5a2d;text:#fff
[notify [Succeeded\]] as notify #2d5a2d;text:#fff
[save [Succeeded\]] as save #2d5a2d;text:#fff
[transform [Succeeded\]] as transform #2d5a2d;text:#fff
[validate [Succeeded\]] as validate #2d5a2d;text:#fff

fetch --> flaky_api_call
save --> notify
transform --> save
validate --> transform
fetch --> validate

@enduml
